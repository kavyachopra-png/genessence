{
  "name": "genessence-projects-server",
  "version": "1.0.0",
  "description": "Backend API server for Genessence Project Management Portal",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "npm run prisma:migrate:deploy && node server.js",
    "dev": "nodemon server.js",
    "postinstall": "prisma generate",
    "seed": "node seed.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.22.0",
    "prisma": "^6.15.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}

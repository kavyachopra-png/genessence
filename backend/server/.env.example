# ── Genessence backend environment variables ───────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit the real .env.

# PostgreSQL connection string (Prisma).
# Local dev example:
DATABASE_URL=postgresql://USER@localhost:5432/genessence?schema=public
# Production (e.g. Render) injects its own DATABASE_URL in the dashboard.

# JWT signing secret — REQUIRED. The server refuses to start if this is unset.
# Use a strong random value, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret

# HTTP port the API listens on.
PORT=5050

# Directory for uploaded document files (current storage is local disk).
UPLOAD_DIR=uploads

# ── Optional / production ───────────────────────────────────────────────────
# NODE_ENV=production
# SEED_DATABASE=false          # set true to allow first-run seeding in production
# FRONTEND_URL=https://your-frontend-domain.vercel.app
